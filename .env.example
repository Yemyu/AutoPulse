# Copy this file to config/.env and fill in your real DEEPSEEK_API_KEY.
# config/.env is gitignored and should be deleted after use.
DEEPSEEK_API_KEY=xxxxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LLM call behaviour
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=60
LLM_BATCH_SIZE=50
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.1
